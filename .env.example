# Copy this file to .env and fill in your key.
# The backend reads these from the environment (.env is loaded on startup).

# REQUIRED — use a DEDICATED Anthropic key with a monthly spend cap set in the Console.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: server port (default 8000)
PORT=8000

# ── Cost / abuse guardrails (safe defaults; tune before going public) ──
# Max analyses per IP within the window below (both endpoints combined).
RATE_LIMIT_PER_IP=10
RATE_WINDOW_SECONDS=3600
# Hard cap on billable (cache-miss) runs per UTC day. The service returns 429
# once reached — this bounds the daily spend no matter how many people call.
DAILY_API_BUDGET=300
# How long identical requests are served from cache (seconds). 86400 = 24h.
CACHE_TTL_SECONDS=86400
# Max web searches per evidence run (the main variable cost). Lower = cheaper.
WEB_SEARCH_MAX_USES=4
